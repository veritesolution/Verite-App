<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:fitsSystemWindows="true">

    <!-- Scrollable content area so the bottom button can stay pinned -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/btnFeedbackSettings"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="24dp">

            <!-- Header -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/headerLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="16dp"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="24dp"
                    android:padding="4dp"
                    android:src="@drawable/ic_arrow_back"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/accent_teal" />

                <TextView
                    android:id="@+id/headerTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vérité"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:id="@+id/profileIcon"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="24dp"
                    android:background="@drawable/profile_icon_bg"
                    android:padding="4dp"
                    android:src="@drawable/user"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Main Image (EEG Head) - Reduced height from chat page -->
            <ImageView
                android:id="@+id/imgMain"
                android:layout_width="0dp"
                android:layout_height="180dp"
                android:src="@drawable/eeg_measure_removebg_preview"
                android:scaleType="centerInside"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/headerLayout" />
                
            <TextView
                android:id="@+id/txtOryn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="-40dp"
                android:layout_marginStart="32dp"
                android:text="Oryn"
                android:textColor="#E6FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif"
                android:shadowColor="#000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="5"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/imgMain" />

            <!-- Pinned Chat Input Frame (Non-interactive visual anchor) -->
            <LinearLayout
                android:id="@+id/inputFrame"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/pill_bg"
                android:backgroundTint="#0B211E"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                android:paddingVertical="12dp"
                android:gravity="center_vertical"
                app:layout_constraintTop_toBottomOf="@id/txtOryn">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Write your message"
                    android:textColor="#80FFFFFF"
                    android:textSize="14sp" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="12dp"
                    android:src="@android:drawable/ic_menu_camera"
                    app:tint="#B3FFFFFF" />
                    
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="12dp"
                    android:src="@android:drawable/ic_btn_speak_now"
                    app:tint="#B3FFFFFF" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="12dp"
                    android:src="@android:drawable/ic_menu_send"
                    app:tint="#B3FFFFFF" />
            </LinearLayout>

            <!-- Dark Gray Divider / Background for Chart Area -->
            <View
                android:id="@+id/viewDivider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="24dp"
                android:background="#1AFFFFFF"
                app:layout_constraintTop_toBottomOf="@id/inputFrame"/>

            <!-- Chart Row container -->
            <LinearLayout
                android:id="@+id/chartRowLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="32dp"
                android:layout_marginHorizontal="24dp"
                app:layout_constraintTop_toBottomOf="@id/viewDivider">
                
                <!-- Custom Pie Chart -->
                <com.example.myapplication.ui.components.PieChartView
                    android:id="@+id/pieChartView"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="180dp"
                    tools:ignore="MissingClass" />

                <!-- Keys Legend -->
                <LinearLayout
                    android:layout_width="140dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:background="@drawable/card_bg"
                    android:backgroundTint="#111B1A"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Keys :"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textAlignment="center"
                        android:layout_marginBottom="8dp"/>
                        
                    <!-- The items will be dynamically added or statically included here -->
                    <include layout="@layout/item_summary_key" android:id="@+id/key1" />
                    <include layout="@layout/item_summary_key" android:id="@+id/key2" />
                    <include layout="@layout/item_summary_key" android:id="@+id/key3" />
                    <include layout="@layout/item_summary_key" android:id="@+id/key4" />

                </LinearLayout>
            </LinearLayout>

            <!-- Summarized Text Section -->
            <TextView
                android:id="@+id/tvSummarizedTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="32dp"
                android:text="Summarized Text"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/chartRowLayout"/>

            <TextView
                android:id="@+id/tvSummarizedBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/card_bg"
                android:backgroundTint="#0C1413"
                android:padding="24dp"
                android:text="When device is detected in no use, the device will make an attempt to automatically shut down"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:lineSpacingExtra="8dp"
                android:textAlignment="center"
                app:layout_constraintTop_toBottomOf="@id/tvSummarizedTitle"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <!-- Pinned Feedback Settings Button -->
    <Button
        android:id="@+id/btnFeedbackSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="24dp"
        android:backgroundTint="#13211F"
        android:paddingVertical="16dp"
        android:text="Feedback Settings"
        android:textAllCaps="false"
        android:textColor="@color/white"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
