<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ═══ Premium Page Backgrounds ═══ -->
    <style name="PremiumPage">
        <item name="android:background">@drawable/bg_premium_page</item>
        <item name="android:fitsSystemWindows">true</item>
    </style>

    <!-- ═══ Premium Typography ═══ -->
    <style name="PremiumTitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">26sp</item>
        <item name="android:fontFamily">sans-serif-light</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="PremiumTitle.Large">
        <item name="android:textSize">32sp</item>
    </style>

    <style name="PremiumSubtitle">
        <item name="android:textColor">@color/accent_teal</item>
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">sans-serif-light</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="PremiumBody">
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-light</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>

    <style name="PremiumLabel">
        <item name="android:textColor">@color/text_faint</item>
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="PremiumCaption">
        <item name="android:textColor">@color/text_ultra_faint</item>
        <item name="android:textSize">10sp</item>
        <item name="android:fontFamily">sans-serif-light</item>
        <item name="android:letterSpacing">0.15</item>
    </style>

    <!-- ═══ Premium Cards ═══ -->
    <style name="PremiumCard">
        <item name="cardBackgroundColor">@color/card_bg</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/border_inactive</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="PremiumCard.Elevated">
        <item name="cardBackgroundColor">@color/card_bg_elevated</item>
        <item name="cardElevation">4dp</item>
        <item name="strokeColor">@color/border_active</item>
        <item name="strokeWidth">1.5dp</item>
    </style>

    <!-- ═══ Premium Buttons ═══ -->
    <style name="PremiumButton">
        <item name="android:background">@drawable/bg_premium_button</item>
        <item name="android:textColor">@color/text_active</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:letterSpacing">0.06</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingHorizontal">24dp</item>
        <item name="android:paddingVertical">14dp</item>
    </style>

    <style name="PremiumButton.Secondary">
        <item name="android:background">@drawable/bg_premium_button_outline</item>
        <item name="android:textColor">@color/accent_teal</item>
    </style>

    <!-- ═══ Premium Header ═══ -->
    <style name="PremiumHeader">
        <item name="android:paddingHorizontal">24dp</item>
        <item name="android:paddingVertical">16dp</item>
    </style>
</resources>
