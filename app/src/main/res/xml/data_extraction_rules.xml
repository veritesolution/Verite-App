<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude sensitive data from cloud backup -->
        <exclude domain="sharedpref" path="verite_voice_identity.xml" />
        <exclude domain="sharedpref" path="verite_settings.xml" />
        <exclude domain="database" path="verite_database" />
    </cloud-backup>
    <device-transfer>
        <!-- Allow Room DB transfer between devices -->
        <include domain="database" path="verite_database" />
        <exclude domain="sharedpref" path="verite_voice_identity.xml" />
    </device-transfer>
</data-extraction-rules>
