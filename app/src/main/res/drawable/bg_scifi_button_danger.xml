<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#FF5252">

    <item>
        <layer-list>
            <!-- Outer red halo -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#1AFF1744"/>
                    <corners android:radius="4dp"/>
                </shape>
            </item>
            <!-- Inner container -->
            <item android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
                <shape android:shape="rectangle">
                    <gradient android:startColor="#B3CC0000" android:endColor="#B38B0000" android:angle="135"/>
                    <!-- Inner red line -->
                    <stroke android:width="1dp" android:color="#FF1744"/>
                    <corners android:radius="2dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
</ripple>
