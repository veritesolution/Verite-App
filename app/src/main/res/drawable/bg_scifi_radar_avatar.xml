<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Faint inner glow -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#0A1C9C91"/>
        </shape>
    </item>
    
    <!-- Dashed scanner ring -->
    <item android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
        <shape android:shape="oval">
            <stroke android:width="1dp" android:color="#261C9C91" android:dashWidth="4dp" android:dashGap="8dp"/>
        </shape>
    </item>
    
    <!-- Solid bright accent ring (Outer) -->
    <item android:top="6dp" android:bottom="6dp" android:left="6dp" android:right="6dp">
        <shape android:shape="oval">
            <stroke android:width="2dp" android:color="@color/accent_teal"/>
        </shape>
    </item>

    <!-- Faint dark gradient padding -->
    <item android:top="10dp" android:bottom="10dp" android:left="10dp" android:right="10dp">
        <shape android:shape="oval">
            <solid android:color="#1A000000"/>
        </shape>
    </item>
</layer-list>
