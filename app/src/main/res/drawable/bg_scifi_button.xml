<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/accent_bright">

    <item>
        <layer-list>
            <!-- 1. Glowing Halo (Thick, highly transparent border) -->
            <item android:top="0dp" android:bottom="0dp" android:left="0dp" android:right="0dp">
                <shape android:shape="rectangle">
                    <corners android:radius="14dp" />
                    <solid android:color="#00000000" />
                    <stroke android:width="4dp" android:color="#261C9C91" />
                </shape>
            </item>

            <!-- 2. Dark Background to make the button solid -->
            <item android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="12dp" />
                    <solid android:color="@color/card_bg" />
                </shape>
            </item>

            <!-- 3. Gradient Fill (subtle diagonal gradient inner fill) -->
            <item android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="12dp" />
                    <gradient
                        android:angle="45"
                        android:startColor="#1A2DD4AA"
                        android:endColor="#330D6B65" />
                </shape>
            </item>

            <!-- 4. Inner Neon Border -->
            <item android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="12dp" />
                    <solid android:color="#00000000" />
                    <stroke android:width="1dp" android:color="@color/accent_bright" />
                </shape>
            </item>

        </layer-list>
    </item>
</ripple>
