# ═══════════════════════════════════════════════════════════════
# Verite Production API — Environment Configuration
# Copy to .env and fill in your values. NEVER commit .env to git.
# ═══════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=4
APP_LOG_LEVEL=INFO
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING

# ── JWT Authentication ────────────────────────────────────────
JWT_SECRET=CHANGE_ME_TO_A_DIFFERENT_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_DAYS=30

# ── LLM Providers (set at least ONE) ─────────────────────────
GROQ_API_KEY=
GEMINI_API_KEY=
TOGETHER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Primary provider: groq | gemini | together | openai | anthropic
LLM_PRIMARY_PROVIDER=groq
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024
LLM_TIMEOUT_SECONDS=30

# ── Database ──────────────────────────────────────────────────
# For production use PostgreSQL: postgresql+asyncpg://user:pass@host:5432/verite
# For development/testing: sqlite+aiosqlite:///./verite.db
DATABASE_URL=sqlite+aiosqlite:///./verite.db

# ── Redis (optional, for rate limiting & session cache) ───────
REDIS_URL=redis://localhost:6379/0

# ── Safety Thresholds ─────────────────────────────────────────
CRISIS_SEMANTIC_THRESHOLD=0.68
TOXICITY_THRESHOLD=0.35
MAX_INPUT_CHARS=3000
MAX_HISTORY_TOKENS=4000

# ── RAG ───────────────────────────────────────────────────────
RAG_TOP_K_TECHNIQUES=3
RAG_TOP_K_EXAMPLES=3
RAG_HISTORY_WINDOW=3
FAISS_CACHE_DIR=./data/faiss_cache

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=20
RATE_LIMIT_PER_HOUR=200

# ── CORS (comma-separated origins for your Kotlin app) ───────
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# ── Monitoring (optional) ─────────────────────────────────────
SENTRY_DSN=
PROMETHEUS_ENABLED=false
