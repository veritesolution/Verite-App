# Vérité TMR Server — Environment Variables
# Copy to .env and fill in values. Never commit .env to version control.

# ── Required ───────────────────────────────────────────────────────────────────
# API authentication key — must match X-API-Key header sent by Kotlin app
# PRODUCTION: Must be ≥32 chars. Server will REFUSE to start with the default key.
API_KEY=change-me-to-a-long-random-string

# Environment: "development" or "production"
# Production mode enforces strong API key and stricter security.
ENVIRONMENT=development

# ── Security ───────────────────────────────────────────────────────────────────
# CORS origins (comma-separated). Default allows localhost only.
# Production example: CORS_ORIGINS=https://your-domain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Rate limit: max requests per minute per IP
RATE_LIMIT_PER_MINUTE=120

# Max upload file size in MB
MAX_UPLOAD_MB=50

# ── Optional — LLM concept extraction ─────────────────────────────────────────
# GROQ_API_KEY=gsk_...
# GEMINI_API_KEY=AIza...

# ── Optional — Amazon Polly TTS ───────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=us-east-1

# ── Optional — Storage paths ───────────────────────────────────────────────────
# UPLOAD_DIR=/tmp/verite_uploads
# DB_PATH=/tmp/verite_tmr.db

# ── Server ─────────────────────────────────────────────────────────────────
# PORT=8080
