# local.properties — NOT committed to version control (already in .gitignore)
# Copy this file to local.properties and fill in your values.

# ── Required ──────────────────────────────────────────────────────────────────
# Server URL — use http://10.0.2.2:8080/ when running server on your Mac/PC
# and testing on an Android emulator. For a physical device on your LAN,
# use your machine's actual LAN IP: http://192.168.1.100:8080/
# For production: https://your-server.example.com/
verite.server.url=http://10.0.2.2:8080/

# API key — must exactly match the API_KEY env var set on the server.
verite.api.key=verite-dev-key-change-in-production

# ── Android SDK path (auto-generated by Android Studio) ───────────────────────
# sdk.dir=/Users/yourname/Library/Android/sdk
