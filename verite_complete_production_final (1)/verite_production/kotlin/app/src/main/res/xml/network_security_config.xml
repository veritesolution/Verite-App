<?xml version="1.0" encoding="utf-8"?>
<!--
    Network Security Configuration for Vérité TMR.

    Debug builds: Allow cleartext (http://) to localhost and 10.0.2.2 (emulator).
    Release builds: HTTPS only — no cleartext traffic permitted.

    This replaces the blanket android:usesCleartextTraffic="true" which
    allowed unencrypted traffic to ALL hosts, including production servers.
-->
<network-security-config>
    <!-- Production default: HTTPS only -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Development exceptions: cleartext only to local dev servers -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <!-- Add your LAN development server IP here if needed -->
        <!-- <domain includeSubdomains="false">192.168.1.100</domain> -->
    </domain-config>
</network-security-config>
